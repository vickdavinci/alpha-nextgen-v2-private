# .leanignore - Files to exclude from QuantConnect sync
# This prevents unnecessary files from being uploaded to QC cloud

# ═══════════════════════════════════════════════════════════════════
# TESTING & SCRIPTS (Local development only)
# ═══════════════════════════════════════════════════════════════════
tests/
scripts/

# ═══════════════════════════════════════════════════════════════════
# DOCUMENTATION (Not needed on QC)
# ═══════════════════════════════════════════════════════════════════
docs/
*.md
LICENSE

# ═══════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ═══════════════════════════════════════════════════════════════════
# IDE AND TOOLS
# ═══════════════════════════════════════════════════════════════════
.claude/
.github/
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo

# ═══════════════════════════════════════════════════════════════════
# LEAN CLI LOCAL FILES
# ═══════════════════════════════════════════════════════════════════
.lean/
backtests/
live/
storage/
data/market-data/

# ═══════════════════════════════════════════════════════════════════
# ARCHIVES AND BACKUPS
# ═══════════════════════════════════════════════════════════════════
archive/
*.bak
*.backup
*.old

# ═══════════════════════════════════════════════════════════════════
# OS FILES
# ═══════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════════════
# CREDENTIALS (Never sync these!)
# ═══════════════════════════════════════════════════════════════════
credentials*.json
*_credentials.json
api_keys.json
secrets.json
.env
.env.*
